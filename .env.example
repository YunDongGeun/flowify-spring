# === Flowify Spring Boot 환경변수 ===

# MongoDB
MONGODB_URL=mongodb://localhost:27017/flowify

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT (256비트 이상 시크릿)
JWT_SECRET=your-jwt-secret-key-must-be-at-least-256-bits-long

# AES-256 암호화 키 (Base64 인코딩)
ENCRYPTION_SECRET_KEY=your-base64-encoded-aes-256-key

# FastAPI 연동
FASTAPI_URL=http://localhost:8000
INTERNAL_API_SECRET=your-internal-api-secret

# CORS 허용 도메인
CORS_ALLOWED_ORIGINS=http://localhost:3000

# 서버 포트
SERVER_PORT=8080
