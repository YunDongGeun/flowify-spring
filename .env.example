# MongoDB
MONGODB_URL=mongodb://localhost:27017/flowify

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long!!

# AES-256 Encryption Key (Base64 encoded)
ENCRYPTION_SECRET_KEY=your-base64-encoded-encryption-key

# FastAPI Internal Communication
FASTAPI_URL=http://localhost:8000
INTERNAL_API_SECRET=your-internal-api-secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Server
SERVER_PORT=8080
